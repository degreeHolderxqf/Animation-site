{% comment %}
  Arc Shape Wheel Slider Section
  - Renders cards positioned along a large circular path (arc)
  - Integrates with GSAP & Draggable for premium drag rotation
  - Responsive design with configurable settings
{% endcomment %}

<div class="arc-slider-section section-{{ section.id }}-padding" id="ArcSlider-{{ section.id }}" data-desktop-radius="{{ section.settings.desktop_radius }}" data-mobile-radius="{{ section.settings.mobile_radius }}">


  <div class="arc-slider__container">
    <!-- Custom blend-mode cursor following overlay with navigation chevrons -->
    <div class="arc-slider__cursor">
      <svg class="cursor-arrow cursor-arrow--left" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="15 18 9 12 15 6"></polyline>
      </svg>
      <svg class="cursor-arrow cursor-arrow--right" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="9 18 15 12 9 6"></polyline>
      </svg>
    </div>

    <div class="arc-slider__viewport">
      <!-- Centering positioning wrapper to prevent GSAP transform collisions -->
      <div class="arc-slider__wheel-wrapper">
        <!-- The rotating wheel container -->
        <div class="arc-slider__wheel" role="region" aria-label="Rotating portfolio wheel">
          {%- for block in section.blocks -%}
            {%- if block.settings.image != blank -%}
              <div class="arc-slider__card" 
                   data-index="{{ forloop.index0 }}" 
                   data-title="{{ block.settings.title | escape }}" 
                   data-caption="{{ block.settings.caption | escape }}"
                   data-description="{{ block.settings.description | escape }}"
                   data-link="{{ block.settings.link | default: '#' }}"
                   {{ block.shopify_attributes }}>
                <div class="arc-slider__card-media">
                  <img src="{{ block.settings.image | image_url: width: 800, height: 1200, crop: 'center' }}" 
                       alt="{{ block.settings.image.alt | default: block.settings.title | escape }}" 
                       loading="lazy" 
                       width="400" 
                       height="600">
                </div>
              </div>
            {%- else -%}
              <!-- Placeholder card if no image uploaded -->
              <div class="arc-slider__card placeholder-card" 
                   data-index="{{ forloop.index0 }}" 
                   data-title="Example Title {{ forloop.index }}" 
                   data-caption="Started in 2026"
                   data-description="There is always something beautiful happening. Discover more about our latest updates."
                   data-link="#">
                <div class="arc-slider__card-media">
                  {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                </div>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>
      <!-- Static detail container positioned absolutely below the center card -->
      <div class="arc-slider__active-details">
        <div class="custom-reveal-mask">
          <p class="arc-slider__active-caption custom-reveal-item" style="transition-delay: 0ms;"></p>
        </div>
        <div class="custom-reveal-mask">
          <h3 class="arc-slider__active-title custom-reveal-item" style="transition-delay: 80ms;"></h3 >
        </div>
        <div class="custom-reveal-mask">
          <p class="arc-slider__active-description custom-reveal-item" style="transition-delay: 160ms;"></p>
        </div>
      </div>
    </div>
  </div>
</div>

{{ 'arc-slider.css' | asset_url | stylesheet_tag }}

{%- comment -%} Ensure GSAP, Draggable, and InertiaPlugin are loaded before initializing scripts {%- endcomment -%}
<script src="https://unpkg.com/gsap@3/dist/gsap.min.js" defer="defer"></script>
<script src="https://unpkg.com/gsap@3/dist/Draggable.min.js" defer="defer"></script>
<script src="https://assets.codepen.io/16327/Flip.min.js" defer="defer"></script>
<script src="https://assets.codepen.io/16327/InertiaPlugin.min.js" defer="defer"></script>
<script src="{{ 'arc-slider.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "Arc Shape Wheel Slider",
  "settings": [
    {
      "type": "number",
      "id": "desktop_radius",
      "label": "Wheel Radius (Desktop in px)",
      "default": 3000
    },
    {
      "type": "number",
      "id": "mobile_radius",
      "label": "Wheel Radius (Mobile in px)",
      "default": 1200
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Slide Image"
        },
        {
          "type": "text",
          "id": "caption",
          "label": "Top Caption (e.g. Date/Category)",
          "default": "Started in 2017"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Client Title"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "There's always something happening at Flower Exchange! New products"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Slide Link (optional)"
        }
      ]
    }
  ],
  "max_blocks": 16,
  "presets": [
    {
      "name": "Arc Shape Wheel Slider",
      "category": "Interactive",
      "blocks": [
        { "type": "slide" },
        { "type": "slide" },
        { "type": "slide" },
        { "type": "slide" }
      ]
    }
  ]
}
{% endschema %}
